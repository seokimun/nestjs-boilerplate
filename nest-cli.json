{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/boilerplate/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/boilerplate/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/boilerplate",
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "boilerplate": {
      "type": "application",
      "root": "apps/boilerplate",
      "entryFile": "main",
      "sourceRoot": "apps/boilerplate/src",
      "compilerOptions": {
        "tsConfigPath": "apps/boilerplate/tsconfig.app.json"
      }
    },
    "common-config": {
      "type": "library",
      "root": "libs/common-config",
      "entryFile": "index",
      "sourceRoot": "libs/common-config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common-config/tsconfig.lib.json"
      }
    },
    "crud": {
      "type": "application",
      "root": "apps/crud",
      "entryFile": "main",
      "sourceRoot": "apps/crud/src",
      "compilerOptions": {
        "tsConfigPath": "apps/crud/tsconfig.app.json"
      }
    },
    "user": {
      "type": "application",
      "root": "apps/user",
      "entryFile": "main",
      "sourceRoot": "apps/user/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user/tsconfig.app.json"
      }
    }
  }
}